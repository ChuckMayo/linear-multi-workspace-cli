# Copy to .env (which is .gitignored) for local smoke testing.
#
#   cp .env.example .env
#   # then fill in real values
#
# Both Node 22+ (--env-file=.env) and the smoke script's npm wrappers
# (npm run smoke:phase-2) read this file automatically.

# Linear personal API token. Generate at:
#   https://linear.app/settings/account/security
# Format: lin_api_xxxxxxxxxxxxxxxxxxxx (the workspace command also accepts this).
LINEAR_API_KEY=

# Default team key for smoke runs. Linear team keys are the 2-6 char prefix on
# issue IDs (e.g. ENG-123 → key=ENG). Find yours via:
#   node bin/run.js team list --pretty
# Optional — only used by smoke:phase-2 if --team isn't passed explicitly.
TEAM=

# Optional — pin a specific registered workspace from your config. If unset, the
# CLI uses your active workspace (or LINEAR_API_KEY env, if also set, bypasses
# workspace resolution entirely).
# LINEAR_WORKSPACE=
